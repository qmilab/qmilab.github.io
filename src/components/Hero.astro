---
// Hero section — the 8-second layer
---

<section class="hero">
  <div class="container">
    <p class="hero__lab-name">Quantum & Machine Intelligence Laboratory</p>
    <h1 class="hero__title">QMI Lab</h1>
    <p class="hero__tagline">
      An independent research lab studying intelligence, learning, and representation across classical and quantum computation.
    </p>
    <p class="hero__founder">Founded by Nandan · Principal Researcher</p>
    <div class="hero__actions">
      <a href="#research">Explore research &darr;</a>
      <a href="/manifesto">Read the manifesto &rarr;</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 6rem 0 4.5rem;
  }

  .hero__lab-name {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-blue);
    margin-bottom: var(--space-sm);
  }

  .hero__title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 500;
    color: var(--deep-navy);
    margin-bottom: var(--space-xl);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .hero__tagline {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--dark-gray);
    max-width: 52ch;
    margin-bottom: var(--space-lg);
  }

  .hero__founder {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--med-gray);
    margin-bottom: var(--space-xl);
    letter-spacing: 0.02em;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-xl);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
  }

  .hero__actions a {
    color: var(--deep-navy);
    text-decoration: none;
  }

  .hero__actions a:hover {
    color: var(--accent-blue);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 4rem 0 3rem;
    }

    .hero__actions {
      flex-direction: column;
      gap: var(--space-md);
    }
  }
</style>
