---
interface Props {
  title: string;
  authors: string[];
  pillar: string;
  status: string;
  venue?: string;
  arxiv?: string;
  code?: string;
  abstract?: string;
}

const { title, authors, pillar, status, venue, arxiv, code, abstract } = Astro.props;

const pillarLabels: Record<string, string> = {
  '1': 'Pillar I',
  '2': 'Pillar II',
  '3': 'Pillar III',
  '1-3': 'Pillar I / III',
};

const pillarColors: Record<string, string> = {
  '1': '1',
  '2': '2',
  '3': '3',
  '1-3': 'bridge',
};

const statusLabels: Record<string, string> = {
  'in-preparation': 'In preparation',
  'preprint': 'Preprint',
  'submitted': 'Submitted',
  'accepted': 'Accepted',
  'published': 'Published',
};
---

<div class="pub-entry">
  <h4 class="pub-entry__title">{title}</h4>
  <div class="pub-entry__meta">
    <span class="pub-entry__authors">{authors.join(', ')}</span>
    <span class={`pillar-tag pillar-tag--${pillarColors[pillar]}`}>{pillarLabels[pillar]}</span>
    <span class="status-tag">{statusLabels[status]}</span>
    {venue && <span class="pub-entry__venue">{venue}</span>}
  </div>
  {abstract && <p class="pub-entry__abstract">{abstract}</p>}
  {(arxiv || code) && (
    <div class="pub-entry__links">
      {arxiv && <a href={arxiv} target="_blank" rel="noopener">arXiv</a>}
      {code && <a href={code} target="_blank" rel="noopener">code</a>}
    </div>
  )}
</div>

<style>
  .pub-entry {
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--border-gray);
  }

  .pub-entry:last-child {
    border-bottom: none;
  }

  .pub-entry__title {
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--deep-navy);
    margin-bottom: var(--space-sm);
    margin-top: 0;
  }

  .pub-entry__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-bottom: var(--space-sm);
  }

  .pub-entry__authors {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--med-gray);
  }

  .pub-entry__venue {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--med-gray);
    font-style: italic;
  }

  .pub-entry__abstract {
    font-size: 0.9rem;
    color: var(--med-gray);
    line-height: 1.7;
    max-width: none;
  }

  .pub-entry__links {
    display: flex;
    gap: var(--space-md);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    margin-top: var(--space-sm);
  }

  .pub-entry__links a {
    color: var(--accent-blue);
  }

  .pub-entry__links a:hover {
    color: var(--deep-navy);
  }
</style>
